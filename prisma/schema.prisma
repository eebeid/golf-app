generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ownerId     String?
  courses     Course[]
  lodging     Lodging[]
  messages    Message[]
  photos      Photo[]
  players     Player[]
  restaurants Restaurant[]
  scorecards  Scorecard[]
  settings    Settings?
  teeTimes    TeeTime[]
  owner       User?        @relation(fields: [ownerId], references: [id])
  activities          Activity[]
  budgetLineItems     BudgetLineItem[]
  playerContributions PlayerContribution[]

  @@index([ownerId])
}

model Player {
  id              String           @id @default(uuid())
  name            String
  handicapIndex   Float            @default(0.0)
  hcpRiver        Int              @default(0)
  hcpPlantation   Int              @default(0)
  hcpRNK          Int              @default(0)
  registeredAt    DateTime         @default(now())
  teePlantation   String?          @default("Gold")
  teeRNK          String?          @default("Gold")
  teeRiver        String?          @default("Gold")
  email           String?
  tournamentId    String?
  courseData      Json?            @default("{}")
  phone           String?
  ghin            String?
  roomNumber      String?
  houseNumber     String?
  imageUrl        String?
  isManager       Boolean          @default(false)
  lodgings        LodgingPlayer[]
  tournament      Tournament?      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  restaurants     Restaurant[]
  scores          Score[]
  activitySignups ActivitySignup[]
  contributions   PlayerContribution[]

  @@unique([email, tournamentId])
  @@index([tournamentId])
}

model Score {
  id               String   @id @default(uuid())
  playerId         String
  courseId         String
  hole             Int
  score            Int
  stablefordPoints Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  strokesReceived  Int      @default(0)
  round            Int      @default(1)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, courseId, hole, round])
  @@index([courseId])
  @@index([playerId])
}

model Course {
  id           String     @id @default(uuid())
  name         String
  address      String?
  par          Int        @default(72)
  tees         Json?
  holes        Json?
  tournamentId String
  lat          Float?
  lng          Float?
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  scores       Score[]

  @@index([tournamentId])
}

model Lodging {
  id           String          @id @default(uuid())
  name         String
  address      String?
  url          String?
  notes        String?
  checkIn      String?
  checkOut     String?
  tournamentId String
  image        String?
  unitNumber   String?
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players      LodgingPlayer[]

  @@index([tournamentId])
}

model LodgingPlayer {
  id        String  @id @default(uuid())
  lodgingId String
  playerId  String
  lodging   Lodging @relation(fields: [lodgingId], references: [id], onDelete: Cascade)
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([lodgingId, playerId])
  @@index([playerId])
}

model Restaurant {
  id           String         @id @default(uuid())
  name         String
  address      String?
  cuisine      String?
  url          String?
  phone        String?
  rating       Int?
  notes        String?
  tournamentId String
  date         String?
  lat          Float?
  lng          Float?
  payerId      String?
  paymentLink  String?
  payer        Player?        @relation(fields: [payerId], references: [id], onDelete: SetNull)
  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  signups      DinnerSignup[]

  @@index([tournamentId])
  @@index([payerId])
}

model DinnerSignup {
  id           String     @id @default(uuid())
  restaurantId String
  name         String
  attendees    Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Photo {
  id           String      @id @default(uuid())
  url          String
  caption      String?
  createdAt    DateTime    @default(now())
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

model Settings {
  id                 String      @id @default(uuid())
  numberOfRounds     Int         @default(0)
  roundDates         Json        @default("[]")
  roundCourses       Json        @default("[]")
  roundHandicaps     Json?       @default("[]")
  totalPlayers       Int         @default(0)
  ryderCupConfig     Json?       @default("{\"enabled\": false, \"team1\": [], \"team2\": []}")
  showAccommodations Boolean     @default(true)
  showFood           Boolean     @default(true)
  updatedAt          DateTime    @updatedAt
  logoUrl            String?
  roundTimeConfig    Json        @default("{}")
  showPhotos         Boolean     @default(false)
  tournamentName     String      @default("Golf Tournament")
  tournamentId       String?     @unique
  paypal             String?
  prizes             Json?       @default("[]")
  prizesTitle        String?     @default("Tournament Prizes")
  venmo              String?
  zelle              String?
  closestToPin       Json?       @default("[]")
  longDrive          Json?       @default("[]")
  allowPlayerEdits   Boolean     @default(false)
  timezone           String      @default("America/New_York")
  showChat           Boolean     @default(true)
  showCourses        Boolean     @default(true)
  showLeaderboard    Boolean     @default(true)
  showPlay           Boolean     @default(true)
  showPlayers        Boolean     @default(true)
  showPrizes         Boolean     @default(true)
  showSchedule       Boolean     @default(true)
  showStats          Boolean     @default(true)
  showScorecards     Boolean     @default(true)
  backgroundColor    String?     @default("#0a1a0f")
  sponsorLogos       Json?       @default("[]")
  tournament         Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Message {
  id           String      @id @default(uuid())
  text         String
  createdAt    DateTime    @default(now())
  userId       String
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id])

  @@index([tournamentId])
  @@index([userId])
}

model TeeTime {
  id           String      @id @default(uuid())
  round        Int
  time         String
  players      Json
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                   String       @id @default(cuid())
  name                 String?
  email                String?      @unique
  emailVerified        DateTime?
  image                String?
  isPro                Boolean      @default(false)
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  proTournamentIds     Json?        @default("[]") // Array of tournamentIds unlocked via Event Pass
  accounts             Account[]
  messages             Message[]
  sessions             Session[]
  tournaments          Tournament[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HistoricalTrip {
  id   String   @id @default(uuid())
  name String
  date DateTime @default(now())
  data Json
}

model Scorecard {
  id           String     @id @default(uuid())
  imageUrl     String
  round        Int
  playerIds    Json
  createdAt    DateTime   @default(now())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

model Activity {
  id                   String           @id @default(uuid())
  tournamentId         String
  title                String
  description          String?
  date                 DateTime
  endTime              DateTime?
  location             String?
  cost                 Float?
  maxPeople            Int?
  minPeople            Int?             @default(0)
  reservationsRequired Boolean          @default(false)
  venmoLink            String?
  category             String? // e.g. "Food", "Outing", "Logistics"
  icon                 String? // Emoji (e.g. boat)
  tournament           Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  signups              ActivitySignup[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([tournamentId])
}

model ActivitySignup {
  id         String   @id @default(uuid())
  activityId String
  playerId   String
  status     String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  paid       Boolean  @default(false)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([playerId, activityId])
  @@index([activityId])
}

model BudgetLineItem {
  id            String     @id @default(uuid())
  tournamentId  String
  category      String     @default("Other") // Golf, Lodging, Food, Activities, Transport, Other
  label         String
  estimatedCost Float?
  actualCost    Float?
  paidAt        DateTime?
  notes         String?
  perPlayer     Boolean    @default(false)
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tournamentId])
}

model PlayerContribution {
  id           String   @id @default(uuid())
  tournamentId String
  playerId     String
  amountDue    Float    @default(0)
  amountPaid   Float    @default(0)
  paidAt       DateTime?
  notes        String?
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([playerId])
}
